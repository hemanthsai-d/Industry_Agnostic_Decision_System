APP_NAME=decision-platform
APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

OBSERVABILITY_LOG_FORMAT=json
OBSERVABILITY_SERVICE_NAME=decision-api
METRICS_ENABLED=true
TRACING_ENABLED=false
OTLP_ENDPOINT=http://localhost:4317
OTLP_INSECURE=true
TRACE_SAMPLE_RATIO=1.0

BASE_CONFIDENCE_THRESHOLD=0.65
MAX_AUTO_ESCALATION_PROB=0.55

USE_POSTGRES=false
POSTGRES_DSN=postgresql+psycopg://postgres:postgres@localhost:5432/decision_db
RETRIEVAL_VECTOR_DIM=64
RETRIEVAL_RRF_K=60

USE_REDIS=false
REDIS_URL=redis://localhost:6379/0
RATE_LIMIT_ENABLED=false
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_TENANT_REQUESTS_PER_WINDOW=120
RATE_LIMIT_USER_REQUESTS_PER_WINDOW=60
RATE_LIMIT_FAIL_OPEN=true
RATE_LIMIT_KEY_PREFIX=assist:ratelimit

USE_OPA=false
OPA_URL=http://localhost:8181/v1/data/assist/decision

AUTH_ENABLED=false
JWT_SECRET_KEY=change-me-local-dev-secret
JWT_ALGORITHM=HS256
JWT_ISSUER=decision-platform
JWT_AUDIENCE=decision-platform-api

ROUTING_MODEL_BACKEND=artifact
ROUTING_MODEL_ARTIFACT_PATH=artifacts/models/routing_linear_v1.json
ROUTING_CALIBRATION_ARTIFACT_PATH=artifacts/models/routing_temperature_v1.json
ESCALATION_MODEL_ARTIFACT_PATH=artifacts/models/escalation_linear_v1.json
ESCALATION_CALIBRATION_ARTIFACT_PATH=artifacts/models/escalation_platt_v1.json
MODEL_SERVING_URL=http://localhost:9000/v1/models/routing:predict
MODEL_SERVING_TIMEOUT_SECONDS=2.0
MODEL_SERVING_API_KEY=

GENERATION_BACKEND=template
GENERATION_MODEL=qwen2.5:7b-instruct
GENERATION_OLLAMA_BASE_URL=http://localhost:11434
GENERATION_TIMEOUT_SECONDS=8.0
GENERATION_TEMPERATURE=0.2
GENERATION_MAX_TOKENS=320
GENERATION_MAX_HISTORY_TURNS=8
GENERATION_SIMILARITY_THRESHOLD=0.82
GENERATION_FAIL_OPEN=true
GENERATION_STYLE_EXAMPLES_PATH=artifacts/datasets/style_examples.jsonl
GENERATION_MAX_STYLE_EXAMPLES_PER_PROMPT=2

MODEL_SHADOW_ENABLED=true
CHALLENGER_MODEL_NAME=challenger-routing
CHALLENGER_MODEL_VERSION=v1
CHALLENGER_ROUTING_MODEL_BACKEND=heuristic
CHALLENGER_ROUTING_MODEL_ARTIFACT_PATH=artifacts/models/routing_linear_v1.json
CHALLENGER_ROUTING_CALIBRATION_ARTIFACT_PATH=artifacts/models/routing_temperature_v1.json
CHALLENGER_ESCALATION_MODEL_ARTIFACT_PATH=artifacts/models/escalation_linear_v1.json
CHALLENGER_ESCALATION_CALIBRATION_ARTIFACT_PATH=artifacts/models/escalation_platt_v1.json
CHALLENGER_MODEL_SERVING_URL=http://localhost:9000/v1/models/routing:predict
CHALLENGER_MODEL_SERVING_TIMEOUT_SECONDS=2.0
CHALLENGER_MODEL_SERVING_API_KEY=

CANARY_ROLLOUT_ENABLED=false
CANARY_TRAFFIC_PERCENT=0
MODEL_OPS_ROLLOUT_FROM_DB=true
MODEL_OPS_QUALITY_GATE_MIN_ROUTE_ACCURACY=0.75
MODEL_OPS_QUALITY_GATE_MIN_ESCALATION_RECALL=0.70
MODEL_OPS_QUALITY_GATE_MAX_ECE=0.15
MODEL_OPS_QUALITY_GATE_MAX_ABSTAIN_RATE=0.35
MODEL_OPS_QUALITY_GATE_MIN_SAMPLE_SIZE=200

MODEL_GUARDRAIL_FORCE_HANDOFF_ON_FALLBACK=true
MODEL_GUARDRAIL_CONFIDENCE_LOWER_BOUND=0.05
MODEL_GUARDRAIL_CONFIDENCE_UPPER_BOUND=0.98

EVALUATION_BASELINE_DAYS=14
DRIFT_INPUT_THRESHOLD=0.30
DRIFT_CONFIDENCE_THRESHOLD=0.12
DRIFT_OUTCOME_THRESHOLD=0.10

MODEL_SERVER_BACKEND=artifact

EVENT_BUS_BACKEND=noop
EVENT_BUS_RETRY_ATTEMPTS=3
EVENT_BUS_RETRY_BACKOFF_SECONDS=0.25
PUBSUB_PROJECT_ID=
PUBSUB_TOPIC=assist-events
PUBSUB_PUBLISH_TIMEOUT_SECONDS=5.0

WORKFLOW_BACKEND=noop
WORKFLOW_RETRY_ATTEMPTS=3
WORKFLOW_RETRY_BACKOFF_SECONDS=0.5
TEMPORAL_TARGET_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=assist-handoffs
TEMPORAL_WORKFLOW_NAME=AssistHandoffWorkflow
TEMPORAL_WORKFLOW_RETRY_ATTEMPTS=5
TEMPORAL_WORKFLOW_RETRY_INITIAL_INTERVAL_SECONDS=1.0

ALERTMANAGER_PAGER_WEBHOOK_URL=
ALERTMANAGER_MODEL_ONCALL_WEBHOOK_URL=
ALERTMANAGER_PLATFORM_ONCALL_WEBHOOK_URL=
ALERTMANAGER_TICKET_WEBHOOK_URL=

ALERT_E2E_MODE=local
ALERTMANAGER_URL=http://127.0.0.1:9093
ALERT_WEBHOOK_SINK_PORT=19100
